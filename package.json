{
  "name": "keymaster",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @keymaster/web",
    "build": "npm run build -w @keymaster/web",
    "typecheck": "tsc -b",
    "lint:boundaries": "node scripts/check-boundaries.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "3.2.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@bsv/sdk": "^1.10.4",
    "@noble/curves": "^2.2.0",
    "i18next": "^23.16.8",
    "keymaster-multisig-pool": "^1.5.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-router": "^7.17.0"
  }
